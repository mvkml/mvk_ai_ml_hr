      "cwd": "${workspaceFolder}/mvkapi/fastapi/ucmcpapi",
      "envFile": "${workspaceFolder}/mvkapi/fastapi/ucmcpapi/.env",
      "console": "integratedTerminal"
    }
  ]
}
